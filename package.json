{
  "name": "git-refs-explorer",
  "displayName": "GIT Revision Graph",
  "description": "Visualize Git references and run compare, checkout, merge, and graph workflows from a dedicated VS Code view.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "MIT",
  "homepage": "https://github.com/rodriguesvali/git-revision-graph#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodriguesvali/git-revision-graph.git"
  },
  "bugs": {
    "url": "https://github.com/rodriguesvali/git-revision-graph/issues"
  },
  "keywords": [
    "git",
    "graph",
    "branches",
    "tags",
    "source-control",
    "visualization"
  ],
  "markdown": "github",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Source Control"
  ],
  "activationEvents": [
    "onView:gitRefs.revisionGraphView",
    "onCommand:gitRefs.refresh",
    "onCommand:gitRefs.compareRefs",
    "onCommand:gitRefs.compareWithWorktree",
    "onCommand:gitRefs.checkout",
    "onCommand:gitRefs.merge",
    "onCommand:gitRefs.openRevisionGraph",
    "onCommand:gitRefs.chooseRevisionGraphRepository"
  ],
  "main": "./out/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitRefs",
          "title": "GIT Revision Graph",
          "icon": "media/git-refs.svg"
        }
      ]
    },
    "views": {
      "gitRefs": [
        {
          "id": "gitRefs.revisionGraphView",
          "name": "GIT Revision Graph",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "gitRefs.refresh",
        "title": "Refresh GIT Revision Graph",
        "icon": "$(refresh)"
      },
      {
        "command": "gitRefs.compareRefs",
        "title": "Compare References"
      },
      {
        "command": "gitRefs.compareWithWorktree",
        "title": "Compare With Worktree"
      },
      {
        "command": "gitRefs.checkout",
        "title": "Checkout Reference"
      },
      {
        "command": "gitRefs.merge",
        "title": "Merge Into Current Branch"
      },
      {
        "command": "gitRefs.openRevisionGraph",
        "title": "Open GIT Revision Graph",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitRefs.chooseRevisionGraphRepository",
        "title": "Choose GIT Revision Graph Repository",
        "icon": "$(repo)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitRefs.refresh",
          "when": "view == gitRefs.revisionGraphView",
          "group": "navigation"
        },
        {
          "command": "gitRefs.chooseRevisionGraphRepository",
          "when": "view == gitRefs.revisionGraphView",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run build && tsc -p ./tsconfig.test.json && node --test out-test/test/**/*.test.js",
    "package:vsix": "vsce package",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.2"
  }
}
