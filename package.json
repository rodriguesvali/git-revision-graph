{
  "name": "git-revision-graph",
  "displayName": "Git Revision Graph",
  "description": "Visualize Git revision graphs from VS Code Source Control and run compare, checkout, branch, merge, sync, delete, and diff workflows.",
  "version": "1.5.5",
  "publisher": "rodriguesvali",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/rodriguesvali/git-revision-graph#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodriguesvali/git-revision-graph.git"
  },
  "bugs": {
    "url": "https://github.com/rodriguesvali/git-revision-graph/issues"
  },
  "keywords": [
    "git",
    "graph",
    "branches",
    "tags",
    "compare",
    "diff",
    "merge",
    "checkout",
    "source-control",
    "visualization"
  ],
  "markdown": "github",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "main": "./out/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitRefs.compareRefs",
        "title": "Compare References"
      },
      {
        "command": "gitRefs.compareWithWorktree",
        "title": "Compare With Worktree"
      },
      {
        "command": "gitRefs.checkout",
        "title": "Checkout Reference"
      },
      {
        "command": "gitRefs.merge",
        "title": "Merge Into Current Branch"
      },
      {
        "command": "gitRefs.openRevisionGraphEditor",
        "title": "View Git Revision Graph",
        "icon": {
          "light": "media/icon-source-light.svg",
          "dark": "media/icon-source-dark.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "gitRefs.openRevisionGraphEditor",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "gitRefs.openRevisionGraphEditor",
          "when": "view == scm",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Git Revision Graph",
      "properties": {
        "gitRevisionGraph.traceLoading": {
          "type": "boolean",
          "default": false,
          "description": "Write revision graph load timing diagnostics to the Git Revision Graph output channel."
        },
        "gitRevisionGraph.graphCommandTimeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Maximum time in milliseconds allowed for the revision graph Git log command."
        }
      }
    }
  },
  "scripts": {
    "clean:out": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "prebuild": "npm run clean:out",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "clean:test": "node -e \"require('fs').rmSync('out-test', { recursive: true, force: true })\"",
    "test": "npm run clean:test && npm run build && tsc -p ./tsconfig.test.json && node scripts/run-compiled-tests.mjs",
    "test:platform": "node --test out-test/test/compareResultRestoreExecutor.test.js out-test/test/gitExec.test.js out-test/test/gitFixture.test.js out-test/test/refContentLoader.test.js out-test/test/repositoryMutationCoordinator.test.js out-test/test/revisionGraphLayoutWorkerHost.test.js",
    "benchmark:ci": "npm run build && node scripts/graph-benchmark.mjs --tier ci",
    "benchmark:rc": "npm run build && node scripts/graph-benchmark.mjs --tier rc",
    "package:vsix": "vsce package",
    "publish:current": "vsce publish",
    "publish:patch": "vsce publish patch",
    "publish:minor": "vsce publish minor",
    "publish:major": "vsce publish major"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "d3-dag": "^1.2.1"
  }
}
